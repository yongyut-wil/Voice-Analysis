# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=voice-analysis

# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
LITELLM_STT_MODEL=gpt-4o-mini-transcribe
LITELLM_ANALYSIS_MODEL=claude-sonnet-4-6

# n8n Integration (required — n8n is the primary analysis orchestration layer)
N8N_WEBHOOK_URL=http://localhost:5678
N8N_ANALYSIS_WEBHOOK_PATH=/webhook/voice-analysis
N8N_CALLBACK_SECRET=
N8N_CALLBACK_BASE_URL=http://localhost:3000

# MindsDB Integration (optional — semantic search + analytics agent)
MINDSDB_HOST=http://localhost:47334
MINDSDB_API_KEY=

# App
NODE_ENV=development
