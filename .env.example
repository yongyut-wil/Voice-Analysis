# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=voice-analysis

# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
LITELLM_STT_MODEL=gpt-4o-mini-transcribe
LITELLM_ANALYSIS_MODEL=claude-sonnet-4-6
ANALYSIS_PROMPT_TEMPLATE=
ANALYSIS_SUMMARY_PROMPT=สรุปการประชุมเป็นภาษาไทยแบบละเอียด 6-8 บรรทัด\nบรรทัดที่ 1: หัวข้อการประชุมและวัตถุประสงค์หลัก\nบรรทัดที่ 2: ประเด็นสำคัญที่มีการหารือ\nบรรทัดที่ 3: ปัญหา อุปสรรค หรือข้อกังวลที่ถูกยกขึ้น\nบรรทัดที่ 4: มติหรือข้อสรุปที่ได้จากการประชุม\nบรรทัดที่ 5: งานที่ต้องดำเนินการต่อ (action items)\nบรรทัดที่ 6: ผู้รับผิดชอบหรือหน่วยงานที่เกี่ยวข้อง (ถ้ามี)\nบรรทัดที่ 7: กำหนดเวลา หรือขั้นตอนถัดไป (ถ้ามี)\nบรรทัดที่ 8: หมายเหตุสำคัญหรือประเด็นที่ต้องติดตามเพิ่มเติม (ถ้ามี)

# MindsDB Integration (optional — semantic search + analytics agent)
MINDSDB_HOST=http://localhost:47334
MINDSDB_API_KEY=           # session token หลัง login, หรือ password ถ้า MindsDB รับ Bearer โดยตรง
MINDSDB_USERNAME=admin     # ใช้ใน docker-compose เพื่อเปิด authentication
MINDSDB_PASSWORD=          # ใช้ใน docker-compose + เป็น credentials สำหรับ login

# App
NODE_ENV=development

# ───────────────────────────────────────────────────────────────────────────
# Authentik OIDC SSO (Phase 2 — optional, เปิดใช้เมื่อ Authentik พร้อมแล้ว)
# Values ได้มาจาก: Authentik Admin → Applications → Providers → <Voice Analysis>
#
# ⚠️  AUTHENTIK_* เหล่านี้ถูก READ โดย Supabase GoTrue ไม่ใช่ Node app โดยตรง
#     - Self-hosted Supabase: ใส่ในไฟล์ .env ของ supabase-auth service
#     - Supabase Cloud: ใส่ใน Dashboard → Auth → Providers → Custom OIDC Provider
# ───────────────────────────────────────────────────────────────────────────
# AUTHENTIK_CLIENT_ID=
# AUTHENTIK_CLIENT_SECRET=
# AUTHENTIK_ISSUER_URL=          # e.g. https://auth.example.com/application/o/voice-analysis/
# AUTHENTIK_REDIRECT_URI=        # <supabase-url>/auth/v1/callback
