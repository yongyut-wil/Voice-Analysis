# Voice Analysis — Coolify Docker Compose Deployment
# Copy to Coolify Environment tab and fill in actual values

# ═══════════════════════════════════════════════════════════════════════════
# SUPABASE (external — cloud or self-hosted)
# ═══════════════════════════════════════════════════════════════════════════
SUPABASE_URL=https://supabase.datalab.thcloud.ai
SUPABASE_ANON_KEY=eyJhbGc...  # JWT token for public API access

# ═══════════════════════════════════════════════════════════════════════════
# MinIO (external — S3-compatible storage)
# ═══════════════════════════════════════════════════════════════════════════
MINIO_ENDPOINT=api-minio.thcloud.ai
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=FF...
MINIO_SECRET_KEY=Ny...
MINIO_BUCKET_NAME=dev-voice-analysis
MINIO_PUBLIC_BASE_URL=https://minio.thcloud.ai

# ═══════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy (external — AI/LLM endpoint)
# ═══════════════════════════════════════════════════════════════════════════
LITELLM_BASE_URL=https://models.thcloud.ai/v1
LITELLM_API_KEY=sk-...

# STT (Speech-to-Text) model for audio transcription
LITELLM_STT_MODEL=gpt-4o-mini-transcribe

# Analysis model for conversation quality assessment
LITELLM_ANALYSIS_MODEL=claude-sonnet-4-6

# Optional: Custom analysis prompt template (use {TRANSCRIPTION} as placeholder)
# ANALYSIS_PROMPT_TEMPLATE=...

# ═══════════════════════════════════════════════════════════════════════════
# n8n Workflow Orchestration (set to SKIP_N8N=true for direct pipeline)
# ═══════════════════════════════════════════════════════════════════════════
SKIP_N8N=true
N8N_WEBHOOK_URL=https://n8n.thcloud.ai
N8N_ANALYSIS_WEBHOOK_PATH=/webhook/voice-analysis
N8N_CALLBACK_SECRET=...
# Must be the public HTTPS domain that Coolify assigns to voice-app (e.g., https://voice.thit.io)
N8N_CALLBACK_BASE_URL=https://voice.thit.io

# ═══════════════════════════════════════════════════════════════════════════
# MindsDB (internal Docker service — optional analytics/semantic search)
# ═══════════════════════════════════════════════════════════════════════════
MINDSDB_USERNAME=admin
MINDSDB_PASSWORD=admin123
# Optional: API key generated in MindsDB dashboard (not typically needed for Docker)
# MINDSDB_API_KEY=pat__...

# ═══════════════════════════════════════════════════════════════════════════
# NOTES FOR COOLIFY UI
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. In Coolify Resource Environment tab:
#    - Mark MINIO_SECRET_KEY, LITELLM_API_KEY, N8N_CALLBACK_SECRET, MINDSDB_PASSWORD as "Secret"
#    - Leave other vars as normal
#
# 2. Do NOT set MINDSDB_HOST here — it's hardcoded in docker-compose.coolify.yml
#    as "http://mindsdb:47334" (Docker internal DNS)
#
# 3. Port mapping (set in Coolify Domains tab):
#    - Port 3000 → https://voice.thit.io (or your domain)
#    - Port 47334 → https://mindsdb.thit.io (optional for GUI access)
#
# 4. Update N8N_CALLBACK_BASE_URL to match your actual domain after first deploy
#
# 5. Optional: Change MINDSDB_PASSWORD to a strong value before first deploy
#
# 6. Post-deployment MindsDB setup (optional, requires Supabase Postgres credentials):
#    See docs/coolify-quickstart.md Phase 4
