# ============================================
# Coolify Deployment - Required Environment Variables
# ============================================
# 
# คัดลอกไปใส่ใน Coolify → Secrets (Environment Variables)
# ไม่ต้องใช้ไฟล์นี้โดยตรง — Coolify จัดการ env ผ่าน UI
#

# ============================================
# Supabase (Required)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ============================================
# MinIO (Required - External บน Host)
# ============================================
# MinIO ไม่ได้ deploy กับ Coolify — ใช้ instance ที่มีอยู่บน host
# ต้องการ credentials ของ MinIO ที่รันอยู่

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-secure-secret-key
MINIO_BUCKET_NAME=voice-analysis

# URL สำหรับ public access (presigned URLs)
MINIO_PUBLIC_BASE_URL=https://minio-your-domain.com

# ค่าสำหรับเชื่อมต่อ MinIO ที่ host
# - ถ้า MinIO อยู่บน host เดียวกัน: ใช้ host.docker.internal หรือ IP
# - ถ้า MinIO อยู่ server อื่น: ใช้ domain/IP นั้น
MINIO_ENDPOINT=host.docker.internal  # หรือ IP ของ host/server ที่มี MinIO
MINIO_PORT=9000
MINIO_USE_SSL=false

# ============================================
# LiteLLM / OpenAI Compatible API (Required)
# ============================================
# URL ของ LiteLLM proxy หรือ OpenAI-compatible endpoint
LITELLM_BASE_URL=https://models.thcloud.ai/v1
LITELLM_API_KEY=your-litellm-or-openai-key

# Models ที่ใช้ (optional - มี default ใน code)
LITELLM_STT_MODEL=gpt-4o-mini-transcribe
LITELLM_ANALYSIS_MODEL=claude-3-5-sonnet-20241022

# ============================================
# n8n Webhook (Required)
# ============================================
# Base URL ของ n8n instance (external หรือ internal ก็ได้)
N8N_WEBHOOK_URL=https://n8n-your-domain.com

# Callback URL ที่ n8n จะส่งผลกลับมา
# ใน Coolify จะเป็น domain ที่ Coolify สร้างให้
N8N_CALLBACK_BASE_URL=https://your-app-domain.com

# Secret สำหรับ verify webhook callback (ตั้งอะไรก็ได้ แต่ต้องตรงกับที่ตั้งใน n8n)
N8N_CALLBACK_SECRET=your-random-secret-string

# Webhook path (optional - มี default)
N8N_ANALYSIS_WEBHOOK_PATH=/webhook/voice-analysis

# ============================================
# MindsDB (Optional - ถ้าใช้ MindsDB ใน compose)
# ============================================
# ไม่ต้องแก้ถ้าใช้ docker-compose.coolify.yml — จะ connect อัตโนมัติ
MINDSDB_HOST=http://mindsdb:47334
MINDSDB_API_KEY=
